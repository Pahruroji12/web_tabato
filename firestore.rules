rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Dokumen menu, topping, dan stok boleh dibaca oleh siapa saja (pelanggan & admin).
    // Admin terautentikasi boleh membaca semua dokumen konfigurasi.
    // Seluruh dokumen konfigurasi hanya boleh ditulis/diubah oleh admin terautentikasi.
    match /config/{document} {
      allow read: if document in ['menuData', 'toppings', 'stok'] || request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Riwayat stok hanya boleh dibaca dan ditulis oleh admin yang terautentikasi
    match /config/stokHistory {
      allow read, write: if request.auth != null;
    }

    // Riwayat stok baru (koleksi stokHistory) - audit log imutabel
    match /stokHistory/{docId} {
      allow read, create: if request.auth != null;
      allow update, delete: if false;
    }
    
    // Kredensial lama (adminAuth) - diblokir sepenuhnya karena sudah beralih ke Firebase Auth
    match /config/adminAuth {
      allow read, write: if false;
    }
    
    // Pesanan online: siapa saja boleh membuat pesanan baru (create) JIKA format data valid.
    // Pesanan offline: hanya admin terautentikasi yang boleh membuat pesanan dengan status "selesai".
    // Pelanggan boleh melihat status pesanan miliknya sendiri (read dengan get).
    // Hanya admin terautentikasi yang bisa melihat list semua pesanan (list) atau meng-update statusnya.
    match /pesanan/{orderId} {
      allow create: if request.auth != null
        || (
          request.resource.data.keys().hasAll(['nama_pemesan', 'detail_item', 'total_harga', 'status', 'waktu_pesan', 'sumber'])
          && request.resource.data.status in ['baru', 'menunggu_verifikasi']
          && request.resource.data.total_harga is number
          && request.resource.data.total_harga > 0
          && request.resource.data.sumber == 'online'
        );
      allow get: if true; // Untuk checking resi mandiri
      allow list, update, delete: if request.auth != null;
    }
  }
}
